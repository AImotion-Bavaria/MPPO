        <rdfs:range rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#Device"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#hasSubprocess"/>
            <rdf:Description rdf:about="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#utilizes"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>
    


