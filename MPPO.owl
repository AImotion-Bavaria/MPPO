        <rdfs:domain rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#Parameter"/>
        <rdfs:range rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#Parameter"/>
