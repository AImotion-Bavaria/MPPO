        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#hasProportionalDependingParameter"/>
