        <MPPO:isDirectStaticParamterOf rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#SandLimeBrickUnwrapped"/>
        <MPPO:isDirectlyDependingOn rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#ActualBarValue"/>
        <MPPO:isDirectlyDependingOn rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#ActualHardeningCurve"/>
