        <rdfs:domain rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#Device"/>
        <rdfs:range rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#ProcessStep"/>
    </owl:ObjectProperty>
    


    <!-- https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#usedToCalculate -->

