        <owl:disjointWith rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#StationaryGripper"/>
        <rdfs:comment xml:lang="en">A gripper mounted on the flange of a robot (e.g., the gripper on the KUKA iiwa)</rdfs:comment>
    </owl:Class>
    


    <!-- https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#RobotTask -->

