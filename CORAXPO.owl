        <rdfs:subClassOf rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#ProcessStep"/>
        <rdfs:comment xml:lang="en">A high-level, symbolic task to be performed by a robot. Tasks are realized by sequences of low-level RobotCommands via mppo:hasSubprocess / realizesTask.</rdfs:comment>
    </owl:Class>
    


