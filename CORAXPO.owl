        <rdfs:comment xml:lang="en">The central node hosting the SE-Model and software modules.</rdfs:comment>
    </owl:Class>
    


    <!-- https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#SoftwareModule -->

    <owl:Class rdf:about="https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#SoftwareModule">
        <rdfs:comment xml:lang="en">A logical software component running on a Server. Distinct from mppo:Device because a SoftwareModule is not a physical artefact.</rdfs:comment>
    </owl:Class>
    


    <!-- https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#StationaryGripper -->

    <owl:Class rdf:about="https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#StationaryGripper">
        <rdfs:subClassOf rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#Gripper"/>
        <rdfs:comment xml:lang="en">A fixed gripper mounted on a workbench or fixture (e.g., the Schunk EGI 80 attached to the bench).</rdfs:comment>
    </owl:Class>
    


    <!-- https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#Workspace -->

    <owl:Class rdf:about="https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#Workspace">
        <rdfs:comment xml:lang="en">A bounded physical region in which robots operate</rdfs:comment>
    </owl:Class>
    


    <!-- https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#WorkspaceObject -->

    <owl:Class rdf:about="https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#WorkspaceObject">
        <rdfs:comment xml:lang="en">A manipulable object in the workspace (block, fixture, tool, workpiece). Distinct from mppo:Material because workspace objects are not necessarily production materials. A WorkspaceObject can be assigned the type mppo:Material in addition where appropriate.</rdfs:comment>
    </owl:Class>
    


