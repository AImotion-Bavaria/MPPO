        <rdfs:subClassOf rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/MPPO.owl#ProcessStep"/>
        <owl:disjointWith rdf:resource="https://www.thi.de/forschung/aimotion/ontologies/CORAXPO.owl#RobotTask"/>
        <rdfs:comment xml:lang="en">A low-level, executable instruction sent from the server to a client controller.</rdfs:comment>
